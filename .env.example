# Environment Variables Example
# Copy this file to .env and populate the values.
# NEVER commit .env to source control.

# ── Stripe ───────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_REPLACE_ME
STRIPE_WEBHOOK_SECRET=whsec_REPLACE_ME
STRIPE_CONNECT_CLIENT_ID=ca_REPLACE_ME

# ── PostgreSQL ────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://widgetai:password@localhost:5432/widgetai

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── Authentication ────────────────────────────────────────────────────────────
JWT_PRIVATE_KEY_PATH=./keys/private.pem
JWT_PUBLIC_KEY_PATH=./keys/public.pem

# ── AWS ───────────────────────────────────────────────────────────────────────
AWS_REGION=us-east-1
AWS_DYNAMODB_TABLE_PRODUCTS=widgetai-products
AWS_S3_BUCKET_ASSETS=widgetai-assets

# ── Email ─────────────────────────────────────────────────────────────────────
SENDGRID_API_KEY=SG.REPLACE_ME
EMAIL_FROM=noreply@widgetai.io

# ── Kafka ─────────────────────────────────────────────────────────────────────
KAFKA_BROKERS=localhost:9092
KAFKA_CLIENT_ID=widgetai-local

# ── Observability ─────────────────────────────────────────────────────────────
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
LOG_LEVEL=info
